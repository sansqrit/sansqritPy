{
  "id": "physics_01",
  "uid": "uid_physics_01",
  "title": "Physics Simulation Example 1",
  "cat": "Physics",
  "diff": "Beginner",
  "desc": "Classical and quantum-inspired physics workflows for simulation, optimisation, and analysis.",
  "domain": "Physics Simulation",
  "blocks": [
    {
      "id": "b01",
      "uid": "physics_01_b01",
      "type": "hamiltonian_block",
      "x": 80,
      "y": 180,
      "params": {
        "pauli_string": "0.5*Z0*Z1 + 0.3*X0",
        "format": "pauli_string",
        "compute_ground_state": false,
        "output_var": "ham",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b02",
      "uid": "physics_01_b02",
      "type": "finite_element",
      "x": 240,
      "y": 208,
      "params": {
        "mesh_var": "mesh",
        "physics": "structural",
        "solver": "FEniCS",
        "boundary_conditions_var": "bcs",
        "output_var": "fea",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b03",
      "uid": "physics_01_b03",
      "type": "em_field_sim",
      "x": 400,
      "y": 180,
      "params": {
        "geometry_var": "geometry",
        "method": "FDTD",
        "frequency_ghz": 10,
        "excitation_var": "source",
        "output_var": "em",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b04",
      "uid": "physics_01_b04",
      "type": "optics_sim",
      "x": 560,
      "y": 208,
      "params": {
        "optical_system_var": "optics",
        "simulation": "ray_tracing",
        "source_var": "laser",
        "output_var": "optics",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b05",
      "uid": "physics_01_b05",
      "type": "tensor_network",
      "x": 720,
      "y": 180,
      "params": {
        "ansatz": "MPS",
        "bond_dim": 64,
        "task": "ground_state",
        "hamiltonian_var": "H",
        "output_var": "tensor",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b06",
      "uid": "physics_01_b06",
      "type": "dft_plus_u",
      "x": 880,
      "y": 208,
      "params": {
        "crystal_var": "crystal",
        "U_value_eV": 4,
        "target_species": "Fe",
        "code": "QuantumESPRESSO",
        "output_var": "dftu",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b07",
      "uid": "physics_01_b07",
      "type": "qft_block",
      "x": 1040,
      "y": 180,
      "params": {
        "register": "q",
        "n_qubits": 4,
        "inverse": false,
        "swap_bits": true,
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b08",
      "uid": "physics_01_b08",
      "type": "qdrift_block",
      "x": 1200,
      "y": 208,
      "params": {
        "hamiltonian_var": "H",
        "register": "q",
        "time": 1,
        "n_samples": 100,
        "output_var": "qdrift",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b09",
      "uid": "physics_01_b09",
      "type": "qsim_block",
      "x": 1360,
      "y": 180,
      "params": {
        "hamiltonian_var": "H",
        "register": "q",
        "time": 1.0,
        "method": "Trotter-2",
        "error": 0.001,
        "output_var": "qsim",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b10",
      "uid": "physics_01_b10",
      "type": "qram_block",
      "x": 1520,
      "y": 208,
      "params": {
        "data_var": "data",
        "architecture": "bucket_brigade",
