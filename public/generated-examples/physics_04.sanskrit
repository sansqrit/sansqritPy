{
  "id": "physics_04",
  "uid": "uid_physics_04",
  "title": "Physics Simulation Example 4",
  "cat": "Physics",
  "diff": "Expert",
  "desc": "Classical and quantum-inspired physics workflows for simulation, optimisation, and analysis.",
  "domain": "Physics Simulation",
  "blocks": [
    {
      "id": "b01",
      "uid": "physics_04_b01",
      "type": "nuclear_physics",
      "x": 80,
      "y": 180,
      "params": {
        "reaction": "n+U235",
        "calculation": "Q_value",
        "output_var": "nuclear",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b02",
      "uid": "physics_04_b02",
      "type": "quantum_walk_search",
      "x": 240,
      "y": 208,
      "params": {
        "graph_type": "hypercube",
        "n_vertices": 256,
        "n_marked": 1,
        "shots": 1000,
        "output_var": "qwalk_search",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b03",
      "uid": "physics_04_b03",
      "type": "quantum_counting",
      "x": 400,
      "y": 180,
      "params": {
        "n_qubits": 5,
        "n_precision": 5,
        "oracle_fn": "oracle",
        "shots": 1000,
        "output_var": "qcount",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b04",
