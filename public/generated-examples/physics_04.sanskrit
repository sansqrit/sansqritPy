        "n_burnin": 1000,
        "temperature": 1,
        "algorithm": "Metropolis",
        "output_var": "mc",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b22",
      "uid": "physics_04_b22",
      "type": "molecular_dynamics",
      "x": 3440,
      "y": 208,
      "params": {
        "system_var": "molecule",
        "force_field": "AMBER",
        "n_steps": 100000,
        "timestep_fs": 2,
        "temperature_K": 300,
        "output_var": "md",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b23",
      "uid": "physics_04_b23",
      "type": "topological_phase",
      "x": 3600,
      "y": 180,
      "params": {
        "hamiltonian_var": "H_k",
        "invariant": "Chern_number",
        "n_k_points": 100,
        "output_var": "topo",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b24",
      "uid": "physics_04_b24",
      "type": "fluid_dynamics",
      "x": 3760,
      "y": 208,
      "params": {
        "geometry_var": "domain",
        "solver": "OpenFOAM",
        "reynolds": 1000,
        "n_iter": 1000,
        "output_var": "fluid",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
