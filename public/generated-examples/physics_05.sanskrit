{
  "id": "physics_05",
  "uid": "uid_physics_05",
  "title": "Physics Simulation Example 5",
  "cat": "Physics",
  "diff": "Research",
  "desc": "Classical and quantum-inspired physics workflows for simulation, optimisation, and analysis.",
  "domain": "Physics Simulation",
  "blocks": [
    {
      "id": "b01",
      "uid": "physics_05_b01",
      "type": "hamiltonian_block",
      "x": 80,
      "y": 180,
      "params": {
        "pauli_string": "0.5*Z0*Z1 + 0.3*X0",
        "format": "pauli_string",
        "compute_ground_state": false,
        "output_var": "ham",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b02",
      "uid": "physics_05_b02",
      "type": "qite_block",
      "x": 240,
      "y": 208,
      "params": {
        "hamiltonian": "H",
        "register": "q",
        "beta": 1,
        "db": 0.05,
        "output_var": "qite",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b03",
      "uid": "physics_05_b03",
      "type": "variational_gibbs",
      "x": 400,
      "y": 180,
      "params": {
        "hamiltonian": "H",
        "beta": 1,
        "method": "variational",
        "output_var": "vgibbs",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b04",
      "uid": "physics_05_b04",
      "type": "mbl_sim",
      "x": 560,
      "y": 208,
      "params": {
        "n_spins": 10,
        "disorder_W": 2.5,
        "J_coupling": 1,
        "n_time_steps": 100,
        "output_var": "mbl",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b05",
      "uid": "physics_05_b05",
      "type": "vqls_block",
      "x": 720,
      "y": 180,
      "params": {
        "A_var": "A_pauli",
        "b_state_var": "b_circuit",
        "ansatz": "EfficientSU2",
        "shots": 1000,
        "output_var": "vqls",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
