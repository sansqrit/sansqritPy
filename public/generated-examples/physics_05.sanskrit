      "x": 2000,
      "y": 180,
      "params": {
        "target": 0,
        "noise_model": "none",
        "error_rate": 0.001,
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b14",
      "uid": "physics_05_b14",
      "type": "filter_block",
      "x": 2160,
      "y": 208,
      "params": {
        "data_var": "df",
        "condition": "row.score > 0.5",
        "output_var": "filtered",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b15",
      "uid": "physics_05_b15",
      "type": "map_transform",
      "x": 2320,
      "y": 180,
      "params": {
        "data_var": "df",
        "transform_expr": "x * 1.05",
        "output_var": "mapped",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b16",
      "uid": "physics_05_b16",
      "type": "sort_block",
      "x": 2480,
      "y": 208,
      "params": {
        "data_var": "df",
        "key_expr": "x",
        "descending": false,
        "output_var": "sorted",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b17",
      "uid": "physics_05_b17",
      "type": "groupby_block",
      "x": 2640,
      "y": 180,
      "params": {
        "data_var": "df",
        "key_fn": "x[\"category\"]",
        "agg": "list",
        "output_var": "grouped",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b18",
      "uid": "physics_05_b18",
      "type": "monte_carlo",
      "x": 2800,
      "y": 208,
      "params": {
        "n_samples": 10000,
        "n_burnin": 1000,
        "temperature": 1,
        "algorithm": "Metropolis",
        "output_var": "mc",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b19",
      "uid": "physics_05_b19",
      "type": "molecular_dynamics",
      "x": 2960,
      "y": 180,
      "params": {
        "system_var": "molecule",
        "force_field": "AMBER",
        "n_steps": 100000,
        "timestep_fs": 2,
        "temperature_K": 300,
        "output_var": "md",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b20",
      "uid": "physics_05_b20",
      "type": "topological_phase",
      "x": 3120,
      "y": 208,
      "params": {
        "hamiltonian_var": "H_k",
        "invariant": "Chern_number",
        "n_k_points": 100,
        "output_var": "topo",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b21",
      "uid": "physics_05_b21",
      "type": "fluid_dynamics",
      "x": 3280,
      "y": 180,
      "params": {
        "geometry_var": "domain",
        "solver": "OpenFOAM",
        "reynolds": 1000,
        "n_iter": 1000,
        "output_var": "fluid",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b22",
      "uid": "physics_05_b22",
      "type": "finite_element",
      "x": 3440,
      "y": 208,
      "params": {
        "mesh_var": "mesh",
        "physics": "structural",
        "solver": "FEniCS",
        "boundary_conditions_var": "bcs",
        "output_var": "fea",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b23",
      "uid": "physics_05_b23",
      "type": "em_field_sim",
      "x": 3600,
      "y": 180,
      "params": {
        "geometry_var": "geometry",
        "method": "FDTD",
        "frequency_ghz": 10,
        "excitation_var": "source",
        "output_var": "em",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b24",
      "uid": "physics_05_b24",
      "type": "optics_sim",
      "x": 3760,
      "y": 208,
      "params": {
        "optical_system_var": "optics",
        "simulation": "ray_tracing",
        "source_var": "laser",
        "output_var": "optics",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
