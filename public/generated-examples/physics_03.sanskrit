    {
      "id": "b20",
      "uid": "physics_03_b20",
      "type": "filter_block",
      "x": 3120,
      "y": 208,
      "params": {
        "data_var": "df",
        "condition": "row.score > 0.5",
        "output_var": "filtered",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b21",
      "uid": "physics_03_b21",
      "type": "map_transform",
      "x": 3280,
      "y": 180,
      "params": {
        "data_var": "df",
        "transform_expr": "x * 1.05",
        "output_var": "mapped",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b22",
      "uid": "physics_03_b22",
      "type": "sort_block",
      "x": 3440,
      "y": 208,
      "params": {
        "data_var": "df",
        "key_expr": "x",
        "descending": false,
        "output_var": "sorted",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b23",
      "uid": "physics_03_b23",
      "type": "groupby_block",
      "x": 3600,
      "y": 180,
      "params": {
        "data_var": "df",
        "key_fn": "x[\"category\"]",
        "agg": "list",
        "output_var": "grouped",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b24",
      "uid": "physics_03_b24",
      "type": "monte_carlo",
      "x": 3760,
      "y": 208,
      "params": {
        "n_samples": 10000,
        "n_burnin": 1000,
        "temperature": 1,
        "algorithm": "Metropolis",
        "output_var": "mc",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
