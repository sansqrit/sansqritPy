{
  "id": "physics_03",
  "uid": "uid_physics_03",
  "title": "Physics Simulation Example 3",
  "cat": "Physics",
  "diff": "Advanced",
  "desc": "Classical and quantum-inspired physics workflows for simulation, optimisation, and analysis.",
  "domain": "Physics Simulation",
  "blocks": [
    {
      "id": "b01",
      "uid": "physics_03_b01",
      "type": "condensed_matter",
      "x": 80,
      "y": 180,
      "params": {
        "model": "Hubbard",
        "n_sites": 8,
        "n_particles": 4,
        "output_var": "cm",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b02",
      "uid": "physics_03_b02",
      "type": "qdrift_block",
      "x": 240,
      "y": 208,
      "params": {
        "hamiltonian_var": "H",
        "register": "q",
        "time": 1,
        "n_samples": 100,
        "output_var": "qdrift",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b03",
      "uid": "physics_03_b03",
      "type": "qsim_block",
      "x": 400,
      "y": 180,
      "params": {
        "hamiltonian_var": "H",
        "register": "q",
        "time": 1.0,
        "method": "Trotter-2",
        "error": 0.001,
        "output_var": "qsim",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b04",
      "uid": "physics_03_b04",
      "type": "qram_block",
      "x": 560,
      "y": 208,
      "params": {
        "data_var": "data",
        "architecture": "bucket_brigade",
        "n_address": 4,
        "output_var": "qram",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b05",
      "uid": "physics_03_b05",
      "type": "quantum_walk_search",
      "x": 720,
      "y": 180,
      "params": {
        "graph_type": "hypercube",
        "n_vertices": 256,
        "n_marked": 1,
        "shots": 1000,
        "output_var": "qwalk_search",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b06",
      "uid": "physics_03_b06",
      "type": "quantum_counting",
      "x": 880,
      "y": 208,
      "params": {
        "n_qubits": 5,
        "n_precision": 5,
        "oracle_fn": "oracle",
        "shots": 1000,
        "output_var": "qcount",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b07",
      "uid": "physics_03_b07",
      "type": "qsvt_block",
      "x": 1040,
      "y": 180,
      "params": {
        "block_encoding_var": "block_enc",
        "poly_coeff_var": "poly",
        "register": "q",
        "output_var": "qsvt_result",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b08",
      "uid": "physics_03_b08",
      "type": "qite_block",
      "x": 1200,
      "y": 208,
      "params": {
        "hamiltonian": "H",
        "register": "q",
        "beta": 1,
        "db": 0.05,
        "output_var": "qite",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
