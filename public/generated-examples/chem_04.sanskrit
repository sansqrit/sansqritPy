{
  "id": "chem_04",
  "uid": "uid_chem_04",
  "title": "Chemistry & Drug Discovery Example 4",
  "cat": "Chemistry",
  "diff": "Expert",
  "desc": "Molecular modelling, property prediction, reaction pathway evaluation, and lead optimisation.",
  "domain": "Chemistry & Drug Discovery",
  "blocks": [
    {
      "id": "b01",
      "uid": "chem_04_b01",
      "type": "molecule_init",
      "x": 80,
      "y": 180,
      "params": {
        "molecule_name": "Lead_4",
        "smiles": "[H][H]",
        "charge": 0,
        "multiplicity": 1,
        "basis_set": "STO-3G",
        "output_var": "mol",
        "log_properties": true,
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b02",
      "uid": "chem_04_b02",
      "type": "pharmacophore",
      "x": 240,
      "y": 208,
      "params": {
        "actives_var": "actives",
        "method": "LigandScout",
        "n_features": 5,
        "output_var": "pharmacophore",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b03",
      "uid": "chem_04_b03",
      "type": "solubility_pred",
      "x": 400,
      "y": 180,
