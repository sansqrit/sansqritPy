        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b09",
      "uid": "chem_04_b09",
      "type": "vibrational_modes",
      "x": 1360,
      "y": 180,
      "params": {
        "mol_var": "mol",
        "hessian_method": "DFT",
