        "output_var": "scaffolds",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b07",
      "uid": "chem_04_b07",
      "type": "mmpdb_block",
      "x": 1040,
      "y": 180,
      "params": {
