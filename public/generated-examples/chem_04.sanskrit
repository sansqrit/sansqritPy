        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b05",
      "uid": "chem_04_b05",
      "type": "fp_similarity_screen",
      "x": 720,
      "y": 180,
      "params": {
        "query_mol": "query",
        "library_var": "library",
        "fingerprint": "ECFP4",
        "similarity_threshold": 0.7,
        "output_var": "screen",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b06",
      "uid": "chem_04_b06",
      "type": "scaffold_decomp",
      "x": 880,
      "y": 208,
