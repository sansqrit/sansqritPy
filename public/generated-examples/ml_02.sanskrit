{
  "id": "ml_02",
  "uid": "uid_ml_02",
  "title": "Machine Learning Ops Example 2",
  "cat": "ML",
  "diff": "Intermediate",
  "desc": "Model training support, feature engineering, evaluation, drift monitoring, and operational reporting.",
  "domain": "Machine Learning Ops",
  "blocks": [
    {
      "id": "b01",
      "uid": "ml_02_b01",
      "type": "json_reader",
      "x": 80,
      "y": 180,
      "params": {
        "file_path": "local/ml_2.json",
        "jsonl_mode": false,
        "output_var": "data",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b02",
      "uid": "ml_02_b02",
      "type": "normalizing_flow",
      "x": 240,
      "y": 208,
      "params": {
        "data_var": "data",
        "architecture": "RealNVP",
        "n_flows": 8,
        "epochs": 200,
        "output_model": "flow_model",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b03",
      "uid": "ml_02_b03",
      "type": "shap_explain",
      "x": 400,
      "y": 180,
      "params": {
        "model_var": "model",
        "X_var": "X",
        "explainer": "TreeExplainer",
        "max_display": 20,
        "output_var": "shap_values",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b04",
      "uid": "ml_02_b04",
      "type": "gp_regression",
      "x": 560,
      "y": 208,
      "params": {
        "X_train": "X_train",
        "y_train": "y_train",
        "kernel": "RBF",
        "noise_level": 0.01,
        "output_var": "gp_model",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b05",
      "uid": "ml_02_b05",
      "type": "causal_inference",
      "x": 720,
      "y": 180,
      "params": {
        "data_var": "data",
        "treatment_var": "T",
        "outcome_var": "Y",
        "confounders": "[\"age\",\"sex\",\"income\"]",
        "method": "DoWhy",
        "output_var": "causal_effect",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b06",
      "uid": "ml_02_b06",
      "type": "survival_analysis",
      "x": 880,
      "y": 208,
      "params": {
        "data_var": "survival_data",
        "time_col": "time",
        "event_col": "event",
        "model": "Cox_PH",
        "output_var": "surv_result",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b07",
      "uid": "ml_02_b07",
      "type": "active_learning_block",
      "x": 1040,
      "y": 180,
      "params": {
        "unlabelled_var": "X_pool",
        "model_var": "model",
        "strategy": "uncertainty",
        "n_query": 10,
        "output_var": "queried_X",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b08",
      "uid": "ml_02_b08",
      "type": "train_model",
      "x": 1200,
      "y": 208,
      "params": {
        "X_train": "X_train",
        "y_train": "y_train",
        "model_type": "RandomForest",
        "hyperparams": "{\"n_estimators\":100}",
        "cross_validate": true,
        "output_model": "model",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b09",
      "uid": "ml_02_b09",
      "type": "predict_block",
      "x": 1360,
      "y": 180,
      "params": {
        "model_var": "model",
        "X_var": "X_test",
        "return_proba": false,
        "output_var": "y_pred",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b10",
      "uid": "ml_02_b10",
      "type": "xgboost_block",
      "x": 1520,
      "y": 208,
      "params": {
        "X_train": "X_train",
        "y_train": "y_train",
        "library": "LightGBM",
        "n_estimators": 500,
        "max_depth": 6,
        "lr": 0.05,
        "early_stopping": true,
        "output_model": "gbm_model",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b11",
      "uid": "ml_02_b11",
      "type": "automl_block",
      "x": 1680,
      "y": 180,
      "params": {
        "X_train": "X_train",
        "y_train": "y_train",
        "tool": "AutoGluon",
        "time_limit_s": 3600,
        "task": "classification",
        "output_model": "automl_model",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b12",
      "uid": "ml_02_b12",
      "type": "neural_net",
      "x": 1840,
      "y": 208,
      "params": {
        "layers": "[{\"type\":\"Linear\",\"in\":128,\"out\":64},{\"type\":\"ReLU\"},{\"type\":\"Linear\",\"in\":64,\"out\":1}]",
        "loss": "CrossEntropy",
        "optimizer": "Adam",
        "epochs": 100,
        "lr": 0.001,
        "batch_size": 32,
        "output_model": "nn_model",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b13",
      "uid": "ml_02_b13",
      "type": "filter_block",
      "x": 2000,
      "y": 180,
      "params": {
        "data_var": "df",
        "condition": "row.score > 0.5",
        "output_var": "filtered",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b14",
      "uid": "ml_02_b14",
      "type": "map_transform",
      "x": 2160,
      "y": 208,
      "params": {
        "data_var": "df",
        "transform_expr": "x * 1.05",
        "output_var": "mapped",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b15",
      "uid": "ml_02_b15",
      "type": "sort_block",
      "x": 2320,
      "y": 180,
      "params": {
        "data_var": "df",
        "key_expr": "x",
        "descending": false,
        "output_var": "sorted",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b16",
      "uid": "ml_02_b16",
      "type": "groupby_block",
      "x": 2480,
      "y": 208,
      "params": {
        "data_var": "df",
        "key_fn": "x[\"category\"]",
        "agg": "list",
        "output_var": "grouped",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b17",
      "uid": "ml_02_b17",
      "type": "pivot_block",
      "x": 2640,
      "y": 180,
      "params": {
        "data_var": "df",
        "index": "region",
        "columns": "product",
        "values": "revenue",
        "aggfunc": "sum",
        "output_var": "pivoted",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b18",
      "uid": "ml_02_b18",
      "type": "window_transform",
      "x": 2800,
      "y": 208,
      "params": {
        "data_var": "df",
        "window_size": 7,
        "agg": "mean",
        "center": false,
        "output_var": "windowed",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b19",
      "uid": "ml_02_b19",
      "type": "resample_block",
      "x": 2960,
      "y": 180,
      "params": {
        "data_var": "df",
        "freq": "1h",
        "method": "mean",
        "output_var": "resampled",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b20",
      "uid": "ml_02_b20",
      "type": "encode_features",
      "x": 3120,
      "y": 208,
      "params": {
        "X_var": "X",
        "col": "category",
        "method": "onehot",
        "output_var": "encoded",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b21",
      "uid": "ml_02_b21",
      "type": "type_cast",
      "x": 3280,
      "y": 180,
      "params": {
        "input_var": "x",
        "to_type": "float",
        "output_var": "casted",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b22",
      "uid": "ml_02_b22",
      "type": "progress_bar",
      "x": 3440,
      "y": 208,
      "params": {
        "iterable_var": "items",
        "description": "Processing",
        "leave": true,
        "output_var": "item",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b23",
      "uid": "ml_02_b23",
      "type": "data_version",
      "x": 3600,
      "y": 180,
      "params": {
        "data_var": "data",
        "system": "DVC",
        "version_tag": "v1.0.0",
        "message": "Add training data",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b24",
      "uid": "ml_02_b24",
      "type": "conditional_skip",
      "x": 3760,
      "y": 208,
      "params": {
        "condition": "env == \"prod\"",
        "log_skip": true,
        "skip_message": "Skipping: converged",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b25",
      "uid": "ml_02_b25",
      "type": "report_gen",
      "x": 3920,
      "y": 180,
      "params": {
        "title": "MLOps Report 2",
        "data_var": "results",
        "format": "HTML",
        "output_file": "report_ml_2.html",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    }
  ],
