{
  "id": "climate_01",
  "uid": "uid_climate_01",
  "title": "Climate & Earth Systems Example 1",
  "cat": "Climate",
  "diff": "Beginner",
  "desc": "Earth system modelling for emissions, hydrology, biodiversity, and energy transition planning.",
  "domain": "Climate & Earth Systems",
  "blocks": [
    {
      "id": "b01",
      "uid": "climate_01_b01",
      "type": "climate_model",
      "x": 80,
      "y": 180,
      "params": {
        "config_var": "gcm_config",
        "model": "simple_EBM",
        "years": 100,
        "scenario": "SSP2-4.5",
        "output_var": "climate_result",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b02",
      "uid": "climate_01_b02",
      "type": "life_cycle_assess",
      "x": 240,
      "y": 208,
      "params": {
        "product_var": "product",
        "functional_unit": "1 kg",
        "method": "ReCiPe",
        "output_var": "lca",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b03",
      "uid": "climate_01_b03",
      "type": "filter_block",
      "x": 400,
      "y": 180,
      "params": {
        "data_var": "df",
        "condition": "row.score > 0.5",
        "output_var": "filtered",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b04",
      "uid": "climate_01_b04",
      "type": "map_transform",
      "x": 560,
      "y": 208,
      "params": {
        "data_var": "df",
        "transform_expr": "x * 1.05",
        "output_var": "mapped",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b05",
      "uid": "climate_01_b05",
      "type": "sort_block",
      "x": 720,
      "y": 180,
      "params": {
        "data_var": "df",
        "key_expr": "x",
        "descending": false,
        "output_var": "sorted",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b06",
      "uid": "climate_01_b06",
      "type": "groupby_block",
      "x": 880,
      "y": 208,
      "params": {
        "data_var": "df",
        "key_fn": "x[\"category\"]",
        "agg": "list",
        "output_var": "grouped",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b07",
      "uid": "climate_01_b07",
      "type": "pivot_block",
      "x": 1040,
      "y": 180,
      "params": {
        "data_var": "df",
        "index": "region",
        "columns": "product",
        "values": "revenue",
        "aggfunc": "sum",
        "output_var": "pivoted",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b08",
      "uid": "climate_01_b08",
      "type": "window_transform",
      "x": 1200,
      "y": 208,
      "params": {
        "data_var": "df",
        "window_size": 7,
        "agg": "mean",
        "center": false,
        "output_var": "windowed",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b09",
      "uid": "climate_01_b09",
      "type": "feature_eng",
      "x": 1360,
      "y": 180,
      "params": {
        "X_var": "X",
        "steps": "[{\"type\":\"StandardScaler\"},{\"type\":\"OneHotEncoder\"}]",
        "output_var": "features",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b10",
      "uid": "climate_01_b10",
      "type": "type_cast",
      "x": 1520,
      "y": 208,
      "params": {
        "input_var": "x",
        "to_type": "float",
        "output_var": "casted",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b11",
      "uid": "climate_01_b11",
      "type": "normalize_block",
      "x": 1680,
      "y": 180,
      "params": {
        "data_var": "df",
        "scaler": "StandardScaler",
        "output_var": "normalised",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b12",
      "uid": "climate_01_b12",
      "type": "missing_impute",
      "x": 1840,
      "y": 208,
      "params": {
        "data_var": "df",
        "strategy": "median",
        "fill_value": "0",
        "output_var": "imputed",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b13",
      "uid": "climate_01_b13",
      "type": "renewable_opt",
      "x": 2000,
      "y": 180,
      "params": {
        "demand_var": "demand",
        "solar_resource_var": "solar",
        "wind_resource_var": "wind",
        "storage_hours": 4,
        "solver": "LP",
        "output_var": "renewable",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b14",
      "uid": "climate_01_b14",
      "type": "wildfire_predict",
      "x": 2160,
      "y": 208,
      "params": {
        "weather_var": "weather",
        "vegetation_var": "vegetation",
        "model": "GBT",
        "output_var": "wildfire",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b15",
      "uid": "climate_01_b15",
      "type": "air_quality",
      "x": 2320,
      "y": 180,
      "params": {
        "emissions_var": "emissions",
        "met_var": "met_data",
        "model": "simple_dispersion",
        "output_var": "air_quality",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b16",
      "uid": "climate_01_b16",
      "type": "hydrology_block",
      "x": 2480,
      "y": 208,
      "params": {
        "precip_var": "precip",
        "dem_var": "dem",
        "model": "HBV",
        "output_var": "hydrology",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b17",
      "uid": "climate_01_b17",
      "type": "biodiversity_block",
      "x": 2640,
      "y": 180,
      "params": {
        "occurrence_var": "occurrences",
        "climate_var": "climate_data",
        "model": "MaxEnt",
        "output_var": "biodiversity",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b18",
      "uid": "climate_01_b18",
      "type": "carbon_offset",
      "x": 2800,
      "y": 208,
      "params": {
        "activity_var": "activity",
        "methodology": "GHG_Protocol",
        "output_var": "offset",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b19",
      "uid": "climate_01_b19",
      "type": "life_cycle_assess",
      "x": 2960,
      "y": 180,
      "params": {
        "product_var": "product",
        "functional_unit": "1 kg",
        "method": "ReCiPe",
        "output_var": "lca",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b20",
      "uid": "climate_01_b20",
      "type": "filter_block",
      "x": 3120,
      "y": 208,
      "params": {
        "data_var": "df",
        "condition": "row.score > 0.5",
        "output_var": "filtered",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b21",
      "uid": "climate_01_b21",
      "type": "map_transform",
      "x": 3280,
      "y": 180,
      "params": {
        "data_var": "df",
        "transform_expr": "x * 1.05",
        "output_var": "mapped",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b22",
      "uid": "climate_01_b22",
      "type": "sort_block",
      "x": 3440,
      "y": 208,
      "params": {
        "data_var": "df",
        "key_expr": "x",
        "descending": false,
        "output_var": "sorted",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b23",
      "uid": "climate_01_b23",
      "type": "groupby_block",
      "x": 3600,
      "y": 180,
      "params": {
        "data_var": "df",
        "key_fn": "x[\"category\"]",
        "agg": "list",
        "output_var": "grouped",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b24",
      "uid": "climate_01_b24",
      "type": "pivot_block",
      "x": 3760,
      "y": 208,
      "params": {
        "data_var": "df",
        "index": "region",
        "columns": "product",
        "values": "revenue",
        "aggfunc": "sum",
        "output_var": "pivoted",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    },
    {
      "id": "b25",
      "uid": "climate_01_b25",
      "type": "report_gen",
      "x": 3920,
      "y": 180,
      "params": {
        "title": "Climate Report 1",
        "data_var": "results",
        "format": "HTML",
        "output_file": "report_climate_1.html",
        "bypass": false,
        "code_override": false,
        "override_code": ""
      }
    }
  ],
  "wires": [
